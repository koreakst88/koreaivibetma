{
  "terminal": {
    "title": "Команды терминала",
    "items": [
      {
        "command": "cd путь/к/папке",
        "description": "Перейти в папку",
        "example": "cd Desktop"
      },
      {
        "command": "cd ..",
        "description": "Вернуться на уровень вверх",
        "example": "cd .."
      },
      {
        "command": "cd ~ (macOS) / cd %USERPROFILE% (Win)",
        "description": "Вернуться в домашнюю папку",
        "example": "cd ~"
      },
      {
        "command": "pwd (macOS) / cd (Win)",
        "description": "Показать текущую папку",
        "example": "pwd"
      },
      {
        "command": "ls (macOS) / dir (Win)",
        "description": "Список файлов",
        "example": "ls"
      },
      {
        "command": "ls -la (macOS) / dir /a (Win)",
        "description": "Список файлов (подробно)",
        "example": "ls -la"
      },
      {
        "command": "mkdir имя_папки",
        "description": "Создать папку",
        "example": "mkdir my-project"
      },
      {
        "command": "touch имя.txt (macOS) / type nul > имя.txt (Win)",
        "description": "Создать файл",
        "example": "touch index.html"
      },
      {
        "command": "cp файл1 файл2 (macOS) / copy файл1 файл2 (Win)",
        "description": "Копировать файл",
        "example": "cp index.html backup.html"
      },
      {
        "command": "mv файл1 путь/ (macOS) / move файл1 путь/ (Win)",
        "description": "Переместить файл",
        "example": "mv file.txt folder/"
      },
      {
        "command": "rm имя.txt (macOS) / del имя.txt (Win)",
        "description": "Удалить файл",
        "example": "rm old.txt"
      },
      {
        "command": "rm -rf папка (macOS) / rmdir /s папка (Win)",
        "description": "Удалить папку",
        "example": "rm -rf old-folder"
      },
      {
        "command": "node -v",
        "description": "Проверить версию Node.js",
        "example": "node -v"
      },
      {
        "command": "npm -v",
        "description": "Проверить версию npm",
        "example": "npm -v"
      },
      {
        "command": "git --version",
        "description": "Проверить версию Git",
        "example": "git --version"
      },
      {
        "command": "clear (macOS) / cls (Win)",
        "description": "Очистить терминал",
        "example": "clear"
      }
    ]
  },
  "git": {
    "title": "Git команды",
    "items": [
      {
        "command": "git init",
        "description": "Инициализировать Git репозиторий",
        "example": "git init"
      },
      {
        "command": "git status",
        "description": "Проверить статус (какие файлы изменены)",
        "example": "git status"
      },
      {
        "command": "git add .",
        "description": "Добавить все файлы в индекс",
        "example": "git add ."
      },
      {
        "command": "git add имя_файла",
        "description": "Добавить конкретный файл",
        "example": "git add index.html"
      },
      {
        "command": "git commit -m \"Сообщение\"",
        "description": "Создать коммит с описанием",
        "example": "git commit -m \"Add cart page\""
      },
      {
        "command": "git push",
        "description": "Отправить изменения на GitHub",
        "example": "git push"
      },
      {
        "command": "git pull",
        "description": "Получить изменения с GitHub",
        "example": "git pull"
      },
      {
        "command": "git branch",
        "description": "Показать все ветки",
        "example": "git branch"
      },
      {
        "command": "git branch имя_ветки",
        "description": "Создать новую ветку",
        "example": "git branch feature"
      },
      {
        "command": "git checkout имя_ветки",
        "description": "Переключиться на ветку",
        "example": "git checkout main"
      },
      {
        "command": "git checkout -b имя_ветки",
        "description": "Создать и переключиться на ветку",
        "example": "git checkout -b develop"
      },
      {
        "command": "git merge имя_ветки",
        "description": "Слить ветки",
        "example": "git merge feature"
      },
      {
        "command": "git log",
        "description": "Показать историю коммитов",
        "example": "git log"
      },
      {
        "command": "git log --oneline",
        "description": "Краткая история коммитов",
        "example": "git log --oneline"
      },
      {
        "command": "git remote add origin URL",
        "description": "Добавить удалённый репозиторий",
        "example": "git remote add origin https://github.com/user/repo.git"
      },
      {
        "command": "git push -u origin main",
        "description": "Первая отправка на GitHub",
        "example": "git push -u origin main"
      }
    ]
  },
